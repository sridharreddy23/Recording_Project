# .env.example - Copy to .env and fill in your values\n\n# AWS Credentials (recommended: use IAM roles or ~/.aws/credentials instead)\nAWS_ACCESS_KEY_ID=your_access_key_here\nAWS_SECRET_ACCESS_KEY=your_secret_key_here\nAWS_DEFAULT_REGION=us-east-1\nAWS_SESSION_TOKEN=your_session_token_if_needed\n\n# Upload Services\nGOFILE_TOKEN=your_gofile_api_token_here\n\n# Optional: Custom timeouts and limits\nSENDGB_WAIT_SECONDS=600\nMAX_DOWNLOAD_WORKERS=10